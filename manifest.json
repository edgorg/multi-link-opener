{
    "manifest_version": 3,
    "name": "Link Opener - Open Links in Selection",
    "version": "1.0.0",
    "description": "Open all links in selected text via the context menu",
    "permissions": [
        "contextMenus",
        "tabs",
        "tabGroups",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16-dark.png",
            "48": "icons/icon48-dark.png",
            "128": "icons/icon128-dark.png"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "icons": {
        "16": "icons/icon16-dark.png",
        "48": "icons/icon48-dark.png",
        "128": "icons/icon128-dark.png"
    }
}
