{
    "manifest_version": 3,
    "name": "Link Grab - Open Links in Selection",
    "version": "1.0.0",
    "description": "Open or copy all links in selected text",
    "permissions": [
        "contextMenus",
        "tabs",
        "tabGroups",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16-dark.png",
            "48": "icons/icon48-dark.png",
            "128": "icons/icon128-dark.png"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "commands": {
        "open-links": {
            "suggested_key": {
                "default": "Ctrl+Shift+L"
            },
            "description": "Open links in selection"
        },
        "copy-links": {
            "suggested_key": {
                "default": "Ctrl+Shift+K"
            },
            "description": "Copy links in selection to clipboard"
        }
    },
    "content_scripts": [
        {
            "matches": [ "<all_urls>" ],
            "js": [ "content/selection-monitor.js" ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16-dark.png",
        "48": "icons/icon48-dark.png",
        "128": "icons/icon128-dark.png"
    }
}
